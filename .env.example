# PostgreSQL
POSTGRES_DB=phishchips
POSTGRES_USER=phishchips
POSTGRES_PASSWORD=changeme_strong_password

# JWT secret (min 32 chars random string)
JWT_SECRET=changeme_jwt_secret_min_32_chars_random

# Admin page password
ADMIN_PASSWORD=changeme_admin_password

# Port exposed on host for the frontend (default 8080)
FRONTEND_PORT=8080
